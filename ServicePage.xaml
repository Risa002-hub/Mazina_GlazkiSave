<Page x:Class="Mazina_GlazkiSave.ServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mazina_GlazkiSave"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ServicePage" FontFamily="Century Gothic">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" Background="#FFE9F9">
            <TextBox Name="TBSearch" Margin="5" TextChanged="TBSearch_TextChanged" FontSize="15" Width="200"></TextBox>
            <ComboBox Name="ComboSort" Margin="5"  SelectionChanged="ComboSort_SelectionChanged" FontSize="18" Width="200">
                <TextBlock>Все</TextBlock>
                <TextBlock>По наименовниюо возрастанию</TextBlock>
                <TextBlock>По наименовнию по убыванию</TextBlock>
                <TextBlock>По приоритету по возрастанию</TextBlock>
                <TextBlock>По приоритету по убыванию</TextBlock>
                <TextBlock>По скидке по возрастанию</TextBlock>
                <TextBlock>По скидке по убыванию</TextBlock>
            </ComboBox>
            <ComboBox Name="ComboType" Margin="5" SelectionChanged="ComboType_SelectionChanged" FontSize="18" Width="150">
                <TextBlock>Все типы</TextBlock>
                <TextBlock>МФО</TextBlock>
                <TextBlock>ООО</TextBlock>
                <TextBlock>ЗАО</TextBlock>
                <TextBlock>МКК</TextBlock>
                <TextBlock>ОАО</TextBlock>
                <TextBlock>ПАО</TextBlock>
            </ComboBox>
        </StackPanel>
        <ListView Grid.Row="1" Name="ServiceListView">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#B175EE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="600"></ColumnDefinition>
                            <ColumnDefinition Width="100"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Image Width="150" Grid.Column="0" Grid.RowSpan="4" Stretch="UniformToFill" HorizontalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="{Binding Logo}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Logo}" Value="{x:Null}">
                                                <Setter Property="Source" Value="/agents/picture.png"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Logo}" Value="">
                                                <Setter Property="Source" Value="/agents/picture.png"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                        </Image>
                        

                        <TextBlock Grid.Column="1" Grid.Row="0" FontSize="20" TextWrapping="Wrap">
                             <TextBlock Text="{Binding AgentTypeTitle }"/>
                             <TextBlock Text=" | "/>
                             <TextBlock Text="{Binding Title }"/>                       
                       </TextBlock>
                        <TextBlock Text="{Binding SalesForYears, StringFormat= {}{0:0} продаж за год }" Grid.Column="1" Grid.Row="1" FontSize="15"/>
                        <TextBlock Text="{Binding Phone}" Grid.Column="1" Grid.Row="2" FontSize="15"/>
                        <TextBlock Grid.Column="1" Grid.Row="3" FontSize="15">
                            <TextBlock Text=" Приоритетность: "/>
                            <TextBlock Text="{Binding Priority}"/>
                        </TextBlock>

                        <TextBlock Text="{Binding Discount, StringFormat={}{0:0}%}" Grid.Column="2"  FontSize="40"/>

                    </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="LeftDirBtn" Content="&lt;" Width="25" Height="25" Click="LeftDirBtn_Click"></Button>
            <ListBox Name="PageListBox" FontSize="20" MouseUp="PageListBox_MouseUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"></WrapPanel>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirBtn" Content="&gt;" Width="25" Height="25" Click="RightDirBtn_Click"></Button>
        </StackPanel>
        <Button Content="Добавить агента" Name="AddBtn" Click="AddBtn_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom"></Button>
        
    </Grid>
</Page>
